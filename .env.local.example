# =============================================================
# Sprint Armi  ·  .env.local.example
# =============================================================
# Copia este archivo como `.env.local` (queda gitignored) y
# completa los valores marcados con  <-- REEMPLAZAR  abajo.
#
# Una vez configurado:
#   npm install
#   npm run dev
#   # abrir http://localhost:3000
# -------------------------------------------------------------

# =============================================================
# 1. Atlassian OAuth 2.0 (3LO) — OBLIGATORIO
# =============================================================
# Cómo crear la app OAuth en Atlassian:
#
#  a) Entra a https://developer.atlassian.com/console/myapps/
#     (logueado con tu cuenta jose.jimenez@tuarmi.com)
#
#  b) Click "Create"  ->  "OAuth 2.0 integration"
#     Nombre sugerido: "Sprint Armi · Dashboard"
#
#  c) En el panel izquierdo abre "Permissions"  ->  "Add"  y agrega
#     DOS APIs:
#
#        [ Jira API ]            -> Configure -> activa los scopes:
#            - read:jira-work
#            - read:jira-user
#            - offline_access
#
#        [ User identity API ]   -> Configure -> activa el scope:
#            - read:me
#            (sin este scope, /me devuelve 403 al autenticar)
#
#     Guarda en cada API.
#
#  d) Abre "Authorization"  ->  "OAuth 2.0 (3LO)"  ->  "Configure".
#     En "Callback URL" agrega:
#        http://localhost:3000/api/auth/callback
#     (cuando deployees, agrega también la URL de prod, ej:
#      https://sprint-armi.vercel.app/api/auth/callback)
#
#  e) Abre "Settings".  Copia:
#        - Client ID       -> pégalo en ATLASSIAN_CLIENT_ID
#        - Secret          -> click "Show" / "Copy"  -> ATLASSIAN_CLIENT_SECRET
#
ATLASSIAN_CLIENT_ID=<-- REEMPLAZAR con el Client ID de la app
ATLASSIAN_CLIENT_SECRET=<-- REEMPLAZAR con el Secret de la app

# =============================================================
# 2. URL pública donde corre la app — OBLIGATORIO
# =============================================================
# Debe coincidir con la Callback URL configurada arriba (sin el path final).
#   - Local:   http://localhost:3000
#   - Vercel:  https://sprint-armi.vercel.app  (o tu dominio)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# =============================================================
# 3. Jira target — opcional pero recomendado
# =============================================================
# - NEXT_PUBLIC_JIRA_SITE: URL del workspace Jira. Se usa como link
#   en el header ("Abrir en Jira") y como validación opcional del cloudId.
# - NEXT_PUBLIC_JIRA_PROJECT_KEY: la clave del proyecto que monitoreamos.
#   Para el equipo Armi es "ADR" (Armi Delivery Remo).
# - NEXT_PUBLIC_JIRA_PROJECT_NAME: nombre legible que aparece en el header.
NEXT_PUBLIC_JIRA_SITE=https://farmatodovirtual.atlassian.net
NEXT_PUBLIC_JIRA_PROJECT_KEY=ADR
NEXT_PUBLIC_JIRA_PROJECT_NAME=Armi Delivery Remo

# =============================================================
# 4. Cifrado de la sesión (iron-session) — OBLIGATORIO
# =============================================================
# Mínimo 32 caracteres, idealmente 48+. Genera uno con:
#
#   openssl rand -base64 48
#
# IMPORTANTE: NO compartas este valor ni lo subas a git.
# Si lo cambias, todas las sesiones existentes se invalidan
# (los usuarios tendrán que volver a loguearse).
SESSION_SECRET=<-- REEMPLAZAR — corre: openssl rand -base64 48

# Nombre de la cookie de sesión (opcional, default: sprint_armi_session)
SESSION_COOKIE_NAME=sprint_armi_session

# =============================================================
# 5. Alertas AM/PM a Slack — opcional pero recomendado
# =============================================================
# El endpoint  POST /api/reports/digest  arma un resumen del
# sprint con coaching personalizado por junior y lo manda a Slack.
# Si configuras Vercel Cron, se dispara 9am y 5pm Caracas (lun-vie).
#
# Cómo crear el Incoming Webhook de Slack:
#   1. https://api.slack.com/apps  ->  Create New App  ->  From scratch
#   2. Nombre: "Sprint Armi Bot"  /  workspace: el del equipo
#   3. Features  ->  Incoming Webhooks  ->  toggle ON
#   4. "Add New Webhook to Workspace"  ->  elige canal (ej. #armi-sprint
#      o un DM contigo mismo si prefieres privacidad)
#   5. Copia la URL (empieza con https://hooks.slack.com/services/...)
SLACK_WEBHOOK_URL=

# Token que protege /api/reports/digest. Genera uno con:
#   openssl rand -hex 24
# Lo necesitarás para pruebas con curl y/o como header X-Reports-Token.
REPORTS_AUTH_TOKEN=

# CRON_SECRET es el token que Vercel Cron envía como
#   Authorization: Bearer <CRON_SECRET>
# Vercel lo gestiona; basta con que aparezca como env var en el proyecto.
# Para dev local lo puedes dejar vacío.
CRON_SECRET=

# =============================================================
# 6. Fetch del sprint sin sesión (para el cron)
# =============================================================
# El cron corre sin cookie, así que no puede usar el OAuth de usuario.
# En su lugar usa Basic auth con tu API token de Atlassian.
#
# Cómo conseguirlo:
#   https://id.atlassian.com/manage-profile/security/api-tokens
#   -> Create API token  ->  copiar valor (sólo se ve una vez)
JIRA_USER_EMAIL=jose.jimenez@tuarmi.com
JIRA_API_TOKEN=

# =============================================================
# 7. Lista de juniors (para personalizar coaching del digest)
# =============================================================
# IDs de Atlassian separados por coma, o emails. Estos miembros
# reciben tips personalizados ("cómo hablarle") en el digest.
# Si dejas vacío, el digest sale sin sección de coaching.
# Tip: en la app, abre el modal "👥 Juniors" y exporta los IDs
# que ya marcaste — o pega aquí los emails.
ARMI_JUNIORS=
