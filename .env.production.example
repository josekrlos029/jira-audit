# =============================================================
# Sprint Armi  ·  .env.production.example
# =============================================================
# Plantilla para configurar las mismas variables en tu hosting
# de producción (Vercel, Cloud Run, AWS, etc).
#
# NO lo subas con valores reales — en Vercel se configuran
# desde "Project Settings -> Environment Variables".
# -------------------------------------------------------------

# --- Atlassian OAuth (3LO) -----------------------------------
# Usa una app OAuth distinta a la de dev (recomendado).
# Recuerda agregar tu Callback URL de PROD:
#   https://<tu-dominio>/api/auth/callback
ATLASSIAN_CLIENT_ID=
ATLASSIAN_CLIENT_SECRET=

# --- URL pública de prod -------------------------------------
# DEBE coincidir con la Callback URL configurada en la app OAuth.
NEXT_PUBLIC_APP_URL=https://sprint-armi.vercel.app

# --- Jira target ---------------------------------------------
NEXT_PUBLIC_JIRA_SITE=https://farmatodovirtual.atlassian.net
NEXT_PUBLIC_JIRA_PROJECT_KEY=ADR
NEXT_PUBLIC_JIRA_PROJECT_NAME=Armi Delivery Remo

# --- Sesión (iron-session) -----------------------------------
# DEBE ser distinto al de dev. Generar con: openssl rand -base64 48
SESSION_SECRET=
SESSION_COOKIE_NAME=sprint_armi_session

# --- Slack digest AM/PM --------------------------------------
SLACK_WEBHOOK_URL=
REPORTS_AUTH_TOKEN=
# Vercel inyecta CRON_SECRET automáticamente para Cron jobs.
# Si tu plan no soporta cron secrets, configúralo manualmente.
CRON_SECRET=

# --- Fetch Jira para el cron (API token Atlassian) -----------
JIRA_USER_EMAIL=
JIRA_API_TOKEN=

# --- Juniors del equipo (coaching personalizado) -------------
ARMI_JUNIORS=
